# Generated as .murder/.env by `murder init`.
# You can also copy this to ~/.config/murder/.env or repo-root .env.

# Primary inference provider (default for crow_handler and planner-API tasks):
# OPENROUTER_API_KEY=

# Free providers (default for notetaker, optional elsewhere):
# CEREBRAS_API_KEY=
# GROQ_API_KEY=

# Auto-free provider pool (murder auto-balances when auto_free is enabled)
# GROQ_API_KEY=...
# CEREBRAS_API_KEY=...

# Optional alternates:
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# LOCAL_API_BASE=http://localhost:8000/v1
# LOCAL_API_KEY=
