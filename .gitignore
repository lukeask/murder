# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Ink TUI bundle — generated into the wheel by the hatch build hook; never committed.
murder/_inktui/

# Web frontend build artifacts — generated; never committed.
# murder/_webui/ is generated into the wheel by the hatch build hook (mirrors murder/_inktui/).
# webui/dist is the Vite build output; webui/node_modules are installed deps.
murder/_webui/
webui/dist/
webui/node_modules/

# Environment
.env

# Murder runtime artifacts
.murder/
# SQLite databases (runtime state; .murder/murder.db plus any stray root copy)
*.db

# Local agent / IDE / handoff (repo-root dot dirs)
.agents/
.claude/
.codex/
.codex-handoff/

# Tooling
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Dev harness recordings (personal data; scrubbed versions to be committed separately)
tools/testing/recordings/

# Editors
.vscode/
.idea/
*.swp
*~

# Stray runtime logs
error.log

# murder
# Append these to your project's .gitignore (or use as-is if you don't
# already have one). `murder init` will add to an existing .gitignore
# rather than overwriting.
# .env files commonly hold OPENROUTER_API_KEY etc.
