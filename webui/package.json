{
  "name": "webui",
  "version": "0.0.0",
  "private": true,
  "description": "Web/mobile React frontend for the murder TUI. Ports the framework-agnostic inktui core (store/selectors/theme/protocol) and talks to the service over a WebSocket bridge to the Unix-socket bus.",
  "type": "module",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ansi-to-html": "^0.7.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "use-sync-external-store": "^1.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^6.0.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.8"
  }
}
