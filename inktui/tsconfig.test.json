{
  // Typechecks test files under the same strict settings as src, but never emits — tests are
  // run by Vitest (via tsx/esbuild), not by tsc. Kept separate so `tsc --build` (the shipped
  // artifact) does not pull test code into dist/.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "rootDir": ".",
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/**/*", "test/**/*", "fixtures/**/*"]
}
